GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEXT_MODEL=
GEMINI_INTENT_MODEL=gemini-3.1-flash-lite
# Dedicated stateless intent-scope/capability diagnostician.
GEMINI_INTENT_REPAIR_ADVISOR_MODEL=gemini-3.1-pro-preview
# Separate stateless repair-only reviewer used after advisor host rejection.
GEMINI_INTENT_REPAIR_REVIEWER_MODEL=gemini-3.5-flash
GEMINI_STEP_PLANNER_MODEL=gemini-3.5-flash
# Dedicated stateless inverse-geometry validation agent.
GEMINI_STEP_REPAIR_ADVISOR_MODEL=gemini-3.1-pro-preview
# Legacy repair-advisor prototype part; retained for migration compatibility.
GEMINI_PARAMETER_MODEL=
GEMINI_VISUAL_VALIDATOR_MODEL=
GEMINI_PATCH_MODEL=
GEMINI_MCP_MODEL=

CADGEN_MAX_ITER=12
# Soft baseline above. A validated agenda may expand to its deterministic
# minimum, but never beyond this absolute accepted-action ceiling.
CADGEN_MAX_ITER_HARD_CEILING=64
CADGEN_OUTPUT_DIR=outputs
CADGEN_INTENT_REPAIR_ATTEMPTS=3
# Diagnose every parsed intent rejection before another authoring call.
CADGEN_INTENT_REPAIR_ADVISOR_ENABLED=true
CADGEN_INTENT_REPAIR_ADVISOR_REQUIRED=true
CADGEN_INTENT_REPAIR_REVIEWER_ENABLED=true
CADGEN_STEP_REPAIR_ATTEMPTS=6
CADGEN_FINAL_REPAIR_ROUNDS=1
# Independent inverse-geometry advisor; required by default for diagnosable rejects.
CADGEN_STEP_REPAIR_ADVISOR_ENABLED=true
CADGEN_STEP_REPAIR_ADVISOR_REQUIRED=true
CADGEN_STEP_REPAIR_ADVISOR_TRIGGER_ATTEMPT=1
CADGEN_STEP_REPAIR_ADVISOR_MAX_CALLS_PER_STEP=3
CADGEN_STEP_REPAIR_ADVISOR_MAX_SIGNATURES_PER_STEP=3
# Extra counterfactual FreeCAD probes remain disabled; static inverse math and
# observed attempt ranges do not require them.
CADGEN_STEP_REPAIR_ADVISOR_PROBE_LIMIT=0
# Require two rejected candidates in the same step before advisor-requested stop.
CADGEN_STEP_TERMINAL_MIN_REJECTIONS=2
# Block physically invalid sweeps; keep the former extra visual reserve advisory.
CADGEN_VALIDATION_ENFORCEMENT=physical_only
CADGEN_STREAM_THINKING_SUMMARY=true

# New synthesis architecture. The intent LLM selects primitive semantics;
# deterministic host code owns exact pose, tangent, closure and numeric action
# compilation. Disable only for legacy comparison/replay experiments.
CADGEN_PRIMITIVE_COMPILER_ENABLED=true
# Global feasibility policy: best_effort records a source-bound minimal
# centerline realization; strict never changes an authored driving dimension;
# off keeps the legacy behavior for controlled experiments.
CADGEN_FEASIBILITY_MODE=best_effort
CADGEN_MAX_UNIFORM_CENTERLINE_SCALE=8
# A rejected geometry digest is a nogood. Exhausted local candidates backjump
# to a causal checkpoint instead of replaying the same current step forever.
CADGEN_CONFLICT_SEARCH_ENABLED=true
CADGEN_MAX_CAUSAL_BACKJUMPS=4

CADGEN_GEMINI_STATEFUL=true
# The code computes a retry-aware default when this variable is omitted.
CADGEN_GEMINI_MAX_CALLS=502
CADGEN_GEMINI_MAX_TOTAL_TOKENS=1000000
CADGEN_GEMINI_MAX_OUTPUT_TOKENS=16384
CADGEN_GEMINI_INTENT_MAX_OUTPUT_TOKENS=16384
# Advisor reasoning and its structured JSON share this budget. 4096 allowed
# reasoning to consume ~3930 tokens and truncate every mediation response.
CADGEN_GEMINI_INTENT_REPAIR_ADVISOR_MAX_OUTPUT_TOKENS=8192
CADGEN_GEMINI_STEP_REPAIR_ADVISOR_MAX_OUTPUT_TOKENS=4096
CADGEN_GEMINI_HISTORY_MAX_TURNS=32
CADGEN_GEMINI_HISTORY_TOKEN_THRESHOLD=48000
CADGEN_GEMINI_REQUEST_TIMEOUT_SEC=180
# Only timeout/rate-limit/server transport failures use these retries. HTTP 400
# invalid schemas go through schema negotiation and never consume geometry
# repair attempts.
CADGEN_PROVIDER_TRANSPORT_RETRIES=2

# Legacy dry-run fixture dimensions only. Production primitive parameters are
# compiled from the accepted source-grounded intent by deterministic host code.
CADGEN_DEFAULT_OUTER_DIAMETER=20
CADGEN_DEFAULT_WALL_THICKNESS=2
CADGEN_DEFAULT_BEND_RADIUS=30

CADGEN_FREECAD_AUTO_OPEN=true
CADGEN_REQUIRE_FREECAD_APP=false
CADGEN_FREECAD_APP_NAME=FreeCAD
CADGEN_FREECAD_PROCESS_NAME=FreeCAD
CADGEN_FREECAD_OPEN_TIMEOUT_SEC=30

CADGEN_FREECAD_MCP_ENABLED=true
CADGEN_FREECAD_STEP_MCP_ENABLED=false
CADGEN_FREECAD_MCP_REQUIRED=true
CADGEN_FREECAD_MCP_COMMAND=uvx
CADGEN_FREECAD_MCP_ARGS=--from freecad-mcp==0.1.19 freecad-mcp --only-text-feedback
CADGEN_FREECAD_MCP_EXECUTE_TOOL=execute_code
CADGEN_FREECAD_MCP_EXECUTE_ARG=code
CADGEN_FREECAD_MCP_TIMEOUT_SEC=360
CADGEN_FREECAD_CAPTURE_VIEWS=true
CADGEN_VISUAL_VALIDATION_MODE=off
CADGEN_MODELING_TOLERANCE=0.0001
