GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEXT_MODEL=
GEMINI_INTENT_MODEL=
GEMINI_STEP_PLANNER_MODEL=
GEMINI_VISUAL_VALIDATOR_MODEL=
GEMINI_PATCH_MODEL=
GEMINI_MCP_MODEL=

CADGEN_MAX_ITER=12
CADGEN_OUTPUT_DIR=outputs
CADGEN_INTENT_REPAIR_ATTEMPTS=3
CADGEN_STEP_REPAIR_ATTEMPTS=6
CADGEN_FINAL_REPAIR_ROUNDS=1
CADGEN_STREAM_THINKING_SUMMARY=true

CADGEN_GEMINI_STATEFUL=true
# The code computes a retry-aware default when this variable is omitted.
CADGEN_GEMINI_MAX_CALLS=178
CADGEN_GEMINI_MAX_TOTAL_TOKENS=1000000
CADGEN_GEMINI_MAX_OUTPUT_TOKENS=16384
CADGEN_GEMINI_INTENT_MAX_OUTPUT_TOKENS=16384
CADGEN_GEMINI_HISTORY_MAX_TURNS=32
CADGEN_GEMINI_HISTORY_TOKEN_THRESHOLD=48000

# Legacy dry-run fixture dimensions only. Production geometry is LLM-authored.
CADGEN_DEFAULT_OUTER_DIAMETER=20
CADGEN_DEFAULT_WALL_THICKNESS=2
CADGEN_DEFAULT_BEND_RADIUS=30

CADGEN_FREECAD_AUTO_OPEN=true
CADGEN_REQUIRE_FREECAD_APP=false
CADGEN_FREECAD_APP_NAME=FreeCAD
CADGEN_FREECAD_PROCESS_NAME=FreeCAD
CADGEN_FREECAD_OPEN_TIMEOUT_SEC=30

CADGEN_FREECAD_MCP_ENABLED=true
CADGEN_FREECAD_STEP_MCP_ENABLED=false
CADGEN_FREECAD_MCP_REQUIRED=true
CADGEN_FREECAD_MCP_COMMAND=uvx
CADGEN_FREECAD_MCP_ARGS=--from freecad-mcp==0.1.19 freecad-mcp --only-text-feedback
CADGEN_FREECAD_MCP_EXECUTE_TOOL=execute_code
CADGEN_FREECAD_MCP_EXECUTE_ARG=code
CADGEN_FREECAD_MCP_TIMEOUT_SEC=360
CADGEN_FREECAD_CAPTURE_VIEWS=true
CADGEN_VISUAL_VALIDATION_MODE=off
CADGEN_MODELING_TOLERANCE=0.0001
